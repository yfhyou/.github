{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "America/New_York",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": false
    },
    {
      "description": "Automerge patch and minor Docker base image bumps",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ],
  "enabledManagers": [
    "github-actions",
    "dockerfile",
    "docker-compose",
    "devcontainer",
    "ansible-galaxy",
    "pip_requirements",
    "pre-commit"
  ]
}
